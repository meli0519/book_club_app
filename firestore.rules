rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Helper functions
    // -----------------------------------------------------------------------

    /// Returns true when the requesting user is authenticated.
    function isAuthenticated() {
      return request.auth != null;
    }

    /// Returns the user document for the requesting user.
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    /// Returns true when the requesting user has role 'leader'.
    /// Requirement 3.4 / 11.2
    function isLeader() {
      return isAuthenticated() &&
             getUserDoc().data.role == 'leader';
    }

    /// Returns true when the requesting user has an active membership.
    /// Requirement 2.3 / 11.1
    function hasActiveMembership() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/memberships/$(request.auth.uid)).data.status == 'active';
    }

    // -----------------------------------------------------------------------
    // users collection
    // Requirement 11.3: each user can only read/write their own document.
    // -----------------------------------------------------------------------
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // -----------------------------------------------------------------------
    // memberships collection
    // Requirement 11.5: leaders can write any membership; a user can create
    // their own initial request.
    // -----------------------------------------------------------------------
    match /memberships/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isLeader());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isLeader();
    }

    // -----------------------------------------------------------------------
    // books collection
    // Read: active members only (Requirement 11.1)
    // Write: leaders only (Requirement 3.4 / 11.2)
    // -----------------------------------------------------------------------
    match /books/{bookId} {
      allow read: if hasActiveMembership();
      allow write: if isLeader();

      // comments subcollection — active members can write (Requirement 11.4)
      match /comments/{commentId} {
        allow read: if hasActiveMembership();
        allow write: if hasActiveMembership();
      }

      // ratings subcollection — active members can write (Requirement 11.4)
      match /ratings/{authorId} {
        allow read: if hasActiveMembership();
        allow write: if hasActiveMembership();
      }

      // reviews subcollection — active members can write (Requirement 11.4)
      match /reviews/{authorId} {
        allow read: if hasActiveMembership();
        allow write: if hasActiveMembership();
      }
    }

    // -----------------------------------------------------------------------
    // meetings collection
    // Read: active members only (Requirement 11.1)
    // Write: leaders only (Requirement 3.4 / 11.2)
    // -----------------------------------------------------------------------
    match /meetings/{meetingId} {
      allow read: if hasActiveMembership();
      allow write: if isLeader();

      // comments subcollection — active members can write (Requirement 11.4)
      match /comments/{commentId} {
        allow read: if hasActiveMembership();
        allow write: if hasActiveMembership();
      }

      // ratings subcollection — active members can write (Requirement 11.4)
      match /ratings/{authorId} {
        allow read: if hasActiveMembership();
        allow write: if hasActiveMembership();
      }
    }

    // -----------------------------------------------------------------------
    // reviewQuestions collection
    // Read: active members; Write: leaders only
    // -----------------------------------------------------------------------
    match /reviewQuestions/{questionId} {
      allow read: if hasActiveMembership();
      allow write: if isLeader();
    }

    // -----------------------------------------------------------------------
    // users/{userId}/personal_books subcollection
    // Requirement 1.3, 8.1, 8.2: only the owner user can read/write
    // -----------------------------------------------------------------------
    match /users/{userId}/personal_books/{bookId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
